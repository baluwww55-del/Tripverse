rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Guard: allow read/write only if authenticated
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicit mappings for all collections
    match /users/{userId} {
      allow read, write: if request.auth != null;

      match /trips/{tripId} {
        allow read, write: if request.auth != null;
      }

      match /chats/{chatId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
