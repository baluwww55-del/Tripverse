rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable core validation helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\:]+$');
    }

    // Entity validator: UserPreferences
    function isValidUserPreferences(data) {
      return data.keys().hasAll(['name', 'email', 'budgetLevel', 'travelStyle', 'dietary', 'preferredActivityLevel'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.budgetLevel is string && (data.budgetLevel == 'budget' || data.budgetLevel == 'moderate' || data.budgetLevel == 'luxury')
        && data.travelStyle is list
        && data.dietary is string && data.dietary.size() <= 200
        && data.preferredActivityLevel is string && (data.preferredActivityLevel == 'low' || data.preferredActivityLevel == 'medium' || data.preferredActivityLevel == 'high');
    }

    // Entity validator: SavedTrip
    function isValidSavedTrip(data) {
      return data.keys().hasAll(['id', 'destination', 'startDate', 'endDate', 'daysCount', 'budget', 'itinerary', 'createdAt'])
        && data.id is string && data.id.size() <= 100
        && data.destination is string && data.destination.size() <= 200
        && data.startDate is string && data.startDate.size() <= 50
        && data.endDate is string && data.endDate.size() <= 50
        && (data.daysCount is int || data.daysCount is float)
        && (data.budget is int || data.budget is float)
        && data.itinerary is list
        && data.createdAt is string && data.createdAt.size() <= 100;
    }

    // Entity validator: ChatMessage
    function isValidChatMessage(data) {
      return data.keys().hasAll(['id', 'sender', 'text', 'timestamp'])
        && data.id is string && data.id.size() <= 100
        && data.sender is string && (data.sender == 'user' || data.sender == 'ai')
        && data.text is string && data.text.size() <= 10000
        && data.timestamp is string && data.timestamp.size() <= 100;
    }

    // Structured matches per user context
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserPreferences(request.resource.data);
      allow update: if isOwner(userId) && isValidUserPreferences(request.resource.data);
      allow delete: if isOwner(userId);

      // Saved trips subcollection
      match /trips/{tripId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(tripId) && isValidSavedTrip(request.resource.data);
        allow update: if isOwner(userId) && isValidId(tripId) && isValidSavedTrip(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // Concierge Chat history logs subcollection
      match /chats/{chatId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(chatId) && isValidChatMessage(request.resource.data);
        allow update: if isOwner(userId) && isValidId(chatId) && isValidChatMessage(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
